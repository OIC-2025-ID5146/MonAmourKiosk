<Window x:Class="MonAmourKiosk.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2000/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2000/xaml"
        xmlns:viewmodels="clr-with:MonAmourKiosk.ViewModels"
        xmlns:views="clr-with:MonAmourKiosk.Views"
        Title="Mon Amour Café &amp; Bistro - Kiosque de Vente"
        WindowState="Maximized" WindowStyle="None"
        Width="1080" Height="1920" Background="#F8F5F0">

	<Window.Resources>
		<DataTemplate DataType="{x:Type viewmodels:AccueilViewModel}">
			<views:AccueilView/>
		</DataTemplate>
		<DataTemplate DataType="{x:Type viewmodels:MenuViewModel}">
			<views:MenuView/>
		</DataTemplate>
		<DataTemplate DataType="{x:Type viewmodels:CheckoutViewModel}">
			<views:CheckoutView/>
		</DataTemplate>
	</Window.Resources>

	<Grid>
		<ContentControl Content="{Binding Navigation.CurrentView}"/>
	</Grid>
</Window>